# Copy this to .env and fill in your API keys
# NEVER commit .env to git
#
# All 7 model families used in Study 1 (CFIM) require the keys below.
# You only need keys for the families you intend to run.
# All families are required for the full Study 1 sweep.

# Llama 3.3 70B via Groq
GROQ_API_KEY=your_groq_api_key_here

# DeepSeek V3 via OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Gemini 2.5 Flash via Google AI Studio
GOOGLE_API_KEY=your_google_ai_studio_api_key_here

# Mistral Small 2506
MISTRAL_API_KEY=your_mistral_api_key_here

# GPT-4o mini via OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Qwen 2.5 72B + Phi-4 via Together.ai
TOGETHER_API_KEY=your_together_api_key_here
